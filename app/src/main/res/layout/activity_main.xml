<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageView
        android:id="@+id/keyImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/cheie" />

    <ro.liviu.carkey.BluetoothWaveView
        android:id="@+id/bluetoothWaveView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no" />

    <ImageView
        android:id="@+id/bleStatusLed"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginStart="65dp"
        android:layout_marginTop="170dp"
        android:adjustViewBounds="true"
        android:clickable="true"
        android:contentDescription="Bluetooth"
        android:focusable="true"
        android:scaleType="fitCenter"
        android:src="@drawable/ble2" />

    <!-- UNLOCK SHADOW -->
    <ImageView
        android:id="@+id/unlockShadow"
        android:layout_width="82dp"
        android:layout_height="82dp"
        android:layout_marginStart="135dp"
        android:layout_marginTop="288dp"
        android:adjustViewBounds="true"
        android:clickable="false"
        android:focusable="false"
        android:scaleType="fitCenter"
        android:src="@drawable/unlock"
        android:tint="#B3000000"
        android:tintMode="src_in" />

    <ImageView
        android:id="@+id/unlockIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginStart="138dp"
        android:layout_marginTop="286dp"
        android:adjustViewBounds="true"
        android:clickable="true"
        android:contentDescription="Deschidere"
        android:focusable="true"
        android:scaleType="fitCenter"
        android:src="@drawable/unlock" />

    <!-- LOCK SHADOW -->
    <ImageView
        android:id="@+id/lockShadow"
        android:layout_width="82dp"
        android:layout_height="82dp"
        android:layout_marginStart="137dp"
        android:layout_marginTop="387dp"
        android:adjustViewBounds="true"
        android:clickable="false"
        android:focusable="false"
        android:scaleType="fitCenter"
        android:src="@drawable/lock"
        android:tint="#B3000000"
        android:tintMode="src_in" />

    <ImageView
        android:id="@+id/lockIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginStart="140dp"
        android:layout_marginTop="385dp"
        android:adjustViewBounds="true"
        android:clickable="true"
        android:contentDescription="Închidere"
        android:focusable="true"
        android:scaleType="fitCenter"
        android:src="@drawable/lock" />

    <!-- TRUNK SHADOW -->
    <ImageView
        android:id="@+id/trunkShadow"
        android:layout_width="82dp"
        android:layout_height="82dp"
        android:layout_marginStart="137dp"
        android:layout_marginTop="477dp"
        android:adjustViewBounds="true"
        android:clickable="false"
        android:focusable="false"
        android:scaleType="fitCenter"
        android:src="@drawable/trunk"
        android:tint="#B3000000"
        android:tintMode="src_in" />

    <ImageView
        android:id="@+id/trunkIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginStart="140dp"
        android:layout_marginTop="475dp"
        android:adjustViewBounds="true"
        android:clickable="true"
        android:contentDescription="Portbagaj"
        android:focusable="true"
        android:scaleType="fitCenter"
        android:src="@drawable/trunk" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="40dp"
        android:text="LLH"
        android:textColor="#FFFFFF"
        android:textSize="24sp" />

</FrameLayout>