<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageView
        android:id="@+id/keyImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/cheie" />

    <ImageView
        android:id="@+id/bleStatusLed"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginStart="85dp"
        android:layout_marginTop="185dp"
        android:adjustViewBounds="true"
        android:clickable="true"
        android:contentDescription="Bluetooth"
        android:focusable="true"
        android:scaleType="fitCenter"
        android:src="@drawable/ble" />

    <ImageView
        android:id="@+id/lockIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginStart="140dp"
        android:layout_marginTop="385dp"
        android:adjustViewBounds="true"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/lock" />

    <ImageView
        android:id="@+id/unlockIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginStart="138dp"
        android:layout_marginTop="286dp"
        android:adjustViewBounds="true"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/unlock" />

    <ImageView
        android:id="@+id/trunkIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginStart="140dp"
        android:layout_marginTop="475dp"
        android:adjustViewBounds="true"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/trunk" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="40dp"
        android:text="LLH"
        android:textColor="#FFFFFF"
        android:textSize="24sp" />

</FrameLayout>